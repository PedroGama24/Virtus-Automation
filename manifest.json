{
  "manifest_version": 3,
  "name": "Virtus Telecom Automation",
  "version": "1.0",
  "description": "Automação de preenchimento de movimentações no sistema Virtus Telecom.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://virtustelecom.app.br/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://virtustelecom.app.br/movimentos/create"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}